---
import BaseLayout from "../layouts/BaseLayout.astro";
import CreateContestForm from "../components/CreateContestForm";
---

<BaseLayout
  title="Rankeame 🏆"
  description="Descubre y rankea lo que sea con tu gente. Crea concursos rápidos o rankings continuos."
>
  <!-- HERO -->
  <section class="bg-gradient-to-b from-orange-50 to-slate-50">
    <div class="max-w-4xl mx-auto px-4 pt-12 pb-10 text-center">
      <div class="text-5xl mb-4">🏆</div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight mb-3">
        Descubre y rankea lo que sea<br class="hidden md:block" />
        <span class="text-orange-500"> con tu gente.</span>
      </h1>
      <p class="text-slate-500 text-base mb-2 leading-relaxed max-w-lg mx-auto">
        Crea concursos rápidos para esta noche o listas continuas de tus sitios favoritos.
      </p>
    </div>
  </section>

  <!-- CROSSROADS GRID -->
  <section class="max-w-4xl mx-auto px-4 pb-16 -mt-2">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Card A: Concurso Rápido -->
      <div
        id="concurso"
        class="bg-white rounded-3xl border border-slate-100 shadow-md hover:shadow-lg transition-all hover:scale-[1.02] p-6 flex flex-col"
      >
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-orange-100 rounded-2xl flex items-center justify-center text-xl shrink-0">
            🏆
          </div>
          <h2 class="text-lg font-bold text-slate-900">Concurso Rápido</h2>
        </div>
        <p class="text-sm text-slate-500 mb-5 leading-relaxed">
          Ideal para catas, fiestas o decisiones de una noche. Sin registro.
        </p>
        <div class="mt-auto">
          <CreateContestForm client:load />
        </div>
      </div>

      <!-- Card B: Ranking Continuo -->
      <div
        class="bg-white rounded-3xl border border-slate-100 shadow-md hover:shadow-lg transition-all hover:scale-[1.02] p-6 flex flex-col"
      >
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-blue-100 rounded-2xl flex items-center justify-center text-xl shrink-0">
            📍
          </div>
          <div class="flex items-center gap-2 flex-wrap">
            <h2 class="text-lg font-bold text-slate-900">Ranking Continuo</h2>
          </div>
        </div>
        <p class="text-sm text-slate-500 mb-5 leading-relaxed">
          Crea una lista viva con tus amigos. Mapas, notas medias y comentarios (Ej: Mejores pizzas de la ciudad).
        </p>
        <div class="mt-auto">
          <a
            href="/r/new"
            class="flex items-center justify-center gap-2 w-full bg-blue-500 hover:bg-blue-600 text-white font-bold px-6 py-3 rounded-2xl text-sm transition"
          >
            Crear Ranking
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
