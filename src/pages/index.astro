---
import BaseLayout from "../layouts/BaseLayout.astro";
import CreateContestForm from "../components/CreateContestForm";
---

<BaseLayout title="Inicio">
  <div class="flex flex-col items-center gap-8 py-12">
    <!-- Hero -->
    <header class="text-center space-y-3">
      <div class="text-5xl font-bold tracking-tight">
        <span
          class="bg-gradient-to-r from-violet-400 to-indigo-400 bg-clip-text text-transparent"
        >
          Rankeame
        </span>
      </div>
      <p class="text-lg text-[var(--color-muted-foreground)]">
        Crea un concurso. Comparte el enlace. Votad juntos — sin registro.
      </p>
    </header>

    <!-- Create contest card -->
    <section
      class="w-full rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-lg"
    >
      <h2 class="mb-5 text-xl font-semibold text-[var(--color-card-foreground)]">
        Crear un nuevo concurso
      </h2>
      <CreateContestForm client:load />
    </section>

    <!-- How it works -->
    <section class="w-full space-y-3">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted-foreground)]">
        Cómo funciona
      </h3>
      <ol class="space-y-2">
        {
          [
            { step: "1", label: "Crea un concurso con un nombre" },
            { step: "2", label: "Comparte el enlace o PIN con tus amigos" },
            { step: "3", label: "Todos votan usando controles deslizantes (1–10)" },
            { step: "4", label: "Observa cómo se actualiza la clasificación en tiempo real" },
          ].map(({ step, label }) => (
            <li class="flex items-center gap-3 text-sm text-[var(--color-foreground)]">
              <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-xs font-bold text-white">
                {step}
              </span>
              {label}
            </li>
          ))
        }
      </ol>
    </section>
  </div>
</BaseLayout>
