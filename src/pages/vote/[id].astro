---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VotingForm from "../../components/VotingForm";
import { supabase } from "../../lib/supabase";
import { getCriteria } from "../../lib/contestTypes";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/");
}

const { data: contest, error } = await supabase
  .from("contests")
  .select("id, name, contest_type, items")
  .eq("id", id)
  .single();

if (error || !contest) {
  return Astro.redirect("/");
}

const items: string[] = Array.isArray(contest.items) ? (contest.items as string[]) : [];

const criteria = getCriteria(contest.contest_type ?? "tortillas");
---

<BaseLayout title={`Votar · ${contest.name}`} description={`Emite tu voto en ${contest.name}`}>
  <div class="max-w-md mx-auto px-4 space-y-6 py-6">
    <!-- Header -->
    <header class="space-y-1 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted-foreground)]">
        Votando en
      </p>
      <h1 class="text-2xl font-bold leading-tight">{contest.name}</h1>
    </header>

    <!-- Voting card -->
    <section
      class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-6"
    >
      {items.length === 0 ? (
        <div class="flex flex-col items-center gap-4 py-10 text-center">
          <span class="text-4xl">⚠️</span>
          <p class="text-sm font-medium text-[var(--color-muted-foreground)]">
            Este concurso no tiene participantes definidos. El anfitrión debe añadirlos antes de poder votar.
          </p>
          <a
            href={`/c/${id}`}
            class="rounded-xl px-5 py-2.5 text-sm font-semibold"
            style="background-color: var(--color-primary); color: var(--color-primary-foreground);"
          >
            Volver al concurso →
          </a>
        </div>
      ) : (
        <VotingForm
          contestId={contest.id}
          contestName={contest.name}
          criteria={criteria}
          items={items}
          client:load
        />
      )}
    </section>

    <!-- Back link -->
    <a
      href={`/c/${id}`}
      class="block text-center text-xs text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] transition"
    >
      ← Volver a la clasificación
    </a>
    <a
      href="/"
      class="block text-center text-xs text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] transition"
    >
      ← Volver al inicio
    </a>
  </div>
</BaseLayout>
