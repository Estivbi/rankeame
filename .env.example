# Supabase configuration
# Copy this file to .env.local and fill in your values from:
# https://supabase.com/dashboard → your project → Settings → API

PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Web3Forms — used by the /contacto page to send emails without a backend
# Get your free access key at https://web3forms.com
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here
